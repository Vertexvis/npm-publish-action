{
  "name": "npm-publish-action",
  "version": "2.3.1",
  "description": "",
  "main": "build/index.js",
  "scripts": {
    "preinstall": "git config core.hooksPath .github/hooks",
    "format": "yarn lint --fix",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx .",
    "test": "jest",
    "test:coverage": "yarn test --coverage",
    "build": "rm -rf build && babel src --out-dir build --extensions '.ts' && ncc build build/index.js --out dist"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^2.2.0",
    "@actions/io": "^1.1.2",
    "glob": "^7.2.2",
    "regenerator-runtime": "^0.13.10"
  },
  "devDependencies": {
    "@babel/cli": "7.8.4",
    "@babel/core": "^7.9.6",
    "@babel/preset-env": "^7.9.6",
    "@babel/preset-typescript": "^7.9.0",
    "@types/glob": "^7.1.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.20.0",
    "@types/regenerator-runtime": "^0.13.1",
    "@vertexvis/eslint-config-vertexvis-typescript": "^0.5.2",
    "@zeit/ncc": "^0.22.2",
    "eslint": "^8.50.0",
    "jest": "^29.0.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "yarn@4.17.0"
}
