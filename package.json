{
  "name": "npm-publish-action",
  "version": "2.5.0",
  "description": "",
  "main": "build/index.js",
  "scripts": {
    "preinstall": "git config core.hooksPath .github/hooks",
    "format": "yarn lint --fix",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx .",
    "test": "jest",
    "test:coverage": "yarn test --coverage",
    "build": "rm -rf build && babel src --out-dir build --extensions '.ts' && ncc build build/index.js --out dist"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^2.2.0",
    "@actions/io": "^1.1.3",
    "glob": "^13.0.6",
    "regenerator-runtime": "^0.13.11"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@types/regenerator-runtime": "^0.13.8",
    "@vercel/ncc": "^0.38.4",
    "@vertexvis/eslint-config-vertexvis-typescript": "^0.5.2",
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "yarn@4.17.0"
}
